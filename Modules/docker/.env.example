# ArangoDB Docker Environment Configuration
# Copy to .env and customize values

# ArangoDB Settings
ARANGO_ROOT_PASSWORD=test123
ARANGO_PORT=8529
ARANGO_DEFAULT_DB_NAME=_system

# Memory & CPU Allocation
ARANGODB_MEMORY=2G
ARANGODB_CORES=2

# SSL/TLS (development = false, production = true)
ARANGO_VERIFY_SSL=false

# Container Names
ARANGODB_CONTAINER=arangodb-server
MCP_CONTAINER=mcp-arangodb

# MCP Configuration
MCP_ENABLED=true
MCP_DEBUG=false

# Development/Production
ENVIRONMENT=development
DEBUG_MODE=false
